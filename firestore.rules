rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn() && ownProfile().data.active == true;
    }

    function manager() {
      return activeUser() && ownProfile().data.role == "manager";
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || activeUser());
      allow list: if activeUser();
      allow create, update, delete: if manager();
    }

    match /orders/{orderId} {
      allow read, create, update, delete: if activeUser();
    }

    match /timeEntries/{entryId} {
      allow read, create, update, delete: if activeUser();
    }

    match /config/{configId} {
      allow read: if activeUser();
      allow write: if manager();
    }
  }
}
